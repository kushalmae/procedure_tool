# =============================================================================
# SatOps Procedures — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# Three ways to run the app:
#   1. Bare Python    — uses SQLite, no env vars needed
#   2. Docker Compose — uses PostgreSQL locally, reads this .env file
#   3. Fly.io         — uses Fly Postgres, env vars set in fly.toml + fly secrets
# =============================================================================

# -----------------------------------------------------------------------------
# Django core
# -----------------------------------------------------------------------------

# Secret key — MUST be a long random string in production.
# Leave the default only for local development.
DJANGO_SECRET_KEY=dev-secret-change-in-production

# Debug mode — True for local dev, False in production.
DJANGO_DEBUG=True

# Comma-separated list of hostnames Django will serve.
# * = accept all (fine for local dev behind Docker).
# Production example: .fly.dev,satops.example.com
DJANGO_ALLOWED_HOSTS=*

# Comma-separated origins allowed for CSRF POST requests.
# Required when serving behind HTTPS / a reverse proxy.
# Leave empty for local dev (Django allows same-origin by default).
# Production example: https://satops-procedures.fly.dev
CSRF_TRUSTED_ORIGINS=

# Redirect all HTTP to HTTPS. Only applies when DJANGO_DEBUG=False.
# Fly.io already forces HTTPS at the edge, so you can set False there
# to avoid a double redirect. Default is True when DEBUG is off.
SECURE_SSL_REDIRECT=True

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# When DATABASE_URL is set, Django uses PostgreSQL via dj-database-url.
# When it is unset or empty, Django falls back to SQLite (ops.db).
#
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
#
# For docker-compose (matches the db service below):
DATABASE_URL=postgres://satops:satops@db:5432/satops

# -----------------------------------------------------------------------------
# PostgreSQL container (used by docker-compose only)
# -----------------------------------------------------------------------------

POSTGRES_DB=satops
POSTGRES_USER=satops
POSTGRES_PASSWORD=satops

# -----------------------------------------------------------------------------
# Superuser auto-creation (used by entrypoint.sh when set)
# -----------------------------------------------------------------------------
# If all three are set, the entrypoint will create a superuser on first run
# (skipped silently if the username already exists).

# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=changeme
